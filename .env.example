# Server port (default: 3000)
PORT=3000

# Optional: Set a secret token to protect your scraper from public use
# If set, requests must include header: Authorization: Bearer YOUR_TOKEN
# Leave blank for no authentication (open access)
AUTH_TOKEN=

# Max pages to crawl per site (default in scraper.js: 60)
MAX_PAGES_PER_SITE=60

# Delay between page requests in ms (default: 300ms - be respectful)
CRAWL_DELAY_MS=300
